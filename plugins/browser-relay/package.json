{
  "name": "@lehoangnnx/openclaw-browser-relay",
  "version": "0.1.0",
  "description": "Let OpenClaw drive your real, logged-in browser via a companion Chrome MV3 extension over a local CDP relay. Resurrected and repackaged from OpenClaw's removed extension-relay path.",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "browser",
    "chrome-extension",
    "cdp",
    "relay",
    "browser-automation",
    "ai-agent"
  ],
  "license": "MIT",
  "author": "Nguyen Le Hoang",
  "repository": {
    "type": "git",
    "url": "https://github.com/lehoangnnx/openclaw-plugins",
    "directory": "plugins/browser-relay"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "extension",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.6.1",
      "minGatewayVersion": "2026.6.1"
    },
    "build": {
      "openclawVersion": "2026.6.1",
      "pluginSdkVersion": "2026.6.1"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "8.21.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "openclaw": "2026.6.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
